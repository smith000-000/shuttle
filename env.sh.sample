#!/usr/bin/env bash

# Shuttle environment sample.
# Copy values into a local ./env.sh or source this file after filling it in:
#   source ./env.sh

# Provider selection:
#   mock | openai | openrouter | custom
export SHUTTLE_PROVIDER="openai"

# Auth selection:
#   auto | api_key | none
export SHUTTLE_AUTH="api_key"

# Model and endpoint defaults.
export SHUTTLE_MODEL="gpt-5-nano-2025-08-07"
# export SHUTTLE_BASE_URL="https://api.openai.com/v1"

# Generic override. If set, Shuttle prefers this over provider-specific keys.
# export SHUTTLE_API_KEY=""

# OpenAI preset:
# export SHUTTLE_PROVIDER="openai"
# export SHUTTLE_AUTH="api_key"
export OPENAI_API_KEY=""

# OpenRouter preset:
# export SHUTTLE_PROVIDER="openrouter"
# export SHUTTLE_AUTH="api_key"
# export SHUTTLE_MODEL="openai/gpt-5"
# export SHUTTLE_BASE_URL="https://openrouter.ai/api/v1"
# export OPENROUTER_API_KEY=""

# Custom Responses-compatible endpoint:
# export SHUTTLE_PROVIDER="custom"
# export SHUTTLE_AUTH="api_key"
# export SHUTTLE_MODEL="gpt-5-nano-2025-08-07"
# export SHUTTLE_BASE_URL="https://your-endpoint.example/v1"

# Optional tmux/session defaults.
# export SHUTTLE_SESSION="shuttle-dev"
# export SHUTTLE_TMUX_SOCKET="shuttle-dev"
# export SHUTTLE_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/shuttle"
# export SHUTTLE_RUNTIME_DIR="${XDG_RUNTIME_DIR:+$XDG_RUNTIME_DIR/shuttle}"
# Allow a less-secure local plaintext fallback for provider secrets when OS keyring
# storage is unavailable. Disabled by default.
# export SHUTTLE_ALLOW_PLAINTEXT_PROVIDER_SECRETS="false"

# Optional trace settings.
# SHUTTLE_TRACE accepts: off | safe | sensitive
# Safe trace redacts commands, terminal contents, key input, and provider bodies.
# Sensitive trace requires explicit consent at launch.
# export SHUTTLE_TRACE="safe"
# export SHUTTLE_TRACE_PATH="${XDG_STATE_HOME:-$HOME/.local/state}/shuttle/trace.log"
# export SHUTTLE_TRACE_CONSENT="false"
